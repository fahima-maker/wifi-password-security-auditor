import re
import random

print("=" * 60)
print("         Wi-Fi Password Security Auditor")
print("=" * 60)

password = input("\nEnter your Wi-Fi Password to Audit: ")

score = 0
feedback = []

# Password length
if len(password) >= 12:
    score += 2
elif len(password) >= 8:
    score += 1
else:
    feedback.append("Use at least 12 characters.")

# Uppercase
if re.search(r"[A-Z]", password):
    score += 1
else:
    feedback.append("Add at least one uppercase letter.")

# Lowercase
if re.search(r"[a-z]", password):
    score += 1
else:
    feedback.append("Add at least one lowercase letter.")

# Number
if re.search(r"\d", password):
    score += 1
else:
    feedback.append("Add at least one number.")

# Special Character
if re.search(r"[!@#$%^&*()_+=<>?/{}~]", password):
    score += 1
else:
    feedback.append("Add at least one special character.")

# Common weak passwords
weak_passwords = [
    "password", "12345678", "admin", "qwerty",
    "welcome", "password123", "wifi12345", "123456789"
]

if password.lower() in weak_passwords:
    score = 0
    feedback.append("This password is extremely common and insecure.")

print("\n" + "=" * 60)
print("               SECURITY REPORT")
print("=" * 60)

if score >= 6:
    print("Password Strength : VERY STRONG")
elif score >= 4:
    print("Password Strength : STRONG")
elif score >= 2:
    print("Password Strength : MEDIUM")
else:
    print("Password Strength : WEAK")

print(f"Password Length   : {len(password)} characters")

if feedback:
    print("\nSecurity Suggestions:")
    for item in feedback:
        print("•", item)
else:
    print("\nExcellent! Your Wi-Fi password follows recommended security practices.")

print("\nSuggested Strong Password:")
characters = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789!@#$%^&*"
strong_password = "".join(random.choice(characters) for _ in range(16))
print(strong_password)

print("\nAudit Completed Successfully.")
